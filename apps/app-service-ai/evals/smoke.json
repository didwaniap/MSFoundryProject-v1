{
  "suite": "azure-app-service-ai-smoke",
  "cases": [
    {
      "id": "tool-status-summary",
      "prompt": "Call the task API tool and summarize the returned status.",
      "expected": ["manufacturing.getLineStatus", "manufacturing.listTasks"]
    },
    {
      "id": "create-three-tasks",
      "prompt": "Create three high-priority onboarding tasks and mark the policy review complete.",
